# ──────────────────────────────────────────────────────────────────────────────
# Frontend environment variables (Vite)
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit it.
# ──────────────────────────────────────────────────────────────────────────────

# ── API URL ───────────────────────────────────────────────────────────────────
# LOCAL DEV:
#   Use /api so the Vite dev-server proxy (vite.config.ts) handles routing.
#   The proxy rewrites /api/* → http://localhost:8000/* automatically.
VITE_API_URL=/api

# PRODUCTION (set this in your Vercel frontend project → Settings → Env Vars):
#   VITE_API_URL=https://your-backend.vercel.app

# ── Dev Proxy ─────────────────────────────────────────────────────────────────
# Where the Vite proxy sends /api/* requests during local development.
# Change this if your local backend runs on a different port.
VITE_API_PROXY_TARGET=http://localhost:8000
