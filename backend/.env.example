# ──────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit it.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres connection string (get it from your Neon dashboard)
# Supported formats:
#   postgres://user:pass@host/db?sslmode=require        (auto-converted)
#   postgresql+asyncpg://user:pass@host/db              (used directly)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_hex_string
ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all (not recommended)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Your deployed frontend URL (added to CORS origins automatically)
FRONTEND_URL=https://your-frontend.vercel.app

# Regex to allow all Vercel preview branches for this project (optional)
CORS_ORIGIN_REGEX=https://your-project.*\.vercel\.app

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
ECHO_SQL=false
